# 生产环境，VUE_APP_BASE_URL可以选择自己配置成需要的接口地址，如"https://api.xxx.com"
# 此文件修改后需要重启项目

# NODE_ENV禁止修改
NODE_ENV=production

# api接口地址
# 请不要将学校内网的真实 IP 提交到仓库。部署到生产环境时请在服务器或 CI 中注入真实的地址，
# 例如：VITE_APP_BASE_URL='http://your.public.host:5001'
# 为空则前端会使用相对地址或本地回退配置
VITE_APP_BASE_URL=''

# 可选：WebSocket 服务地址（优先于 VITE_APP_BASE_URL 用于 websocket 连接）
# 例如：VITE_WS_URL='ws://your.public.host:7002'
VITE_WS_URL=''